# Remote Windows PC configuration
# Copy this to .env and edit values for your setup.
# .env is gitignored — secrets stay local.

PC_HOST=MSI            # Windows PC hostname or IP
PC_IP=192.168.1.7      # Windows PC IP address (used if hostname fails)
PC_USER=yourname       # Windows username
PC_DIR=C:\Users\yourname\Desktop\daz2lora  # Build directory on PC
