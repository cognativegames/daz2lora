                type: "distant",
                position: { x: -80, y: 120, z: 40 },
                intensity: 90,
                color: { r: 1.0, g: 0.95, b: 0.85 },
                rotation: { x: 60, y: -40, z: 0 }
            },
            {
                name: "Sky Fill",
                type: "distant",
                position: { x: 0, y: 150, z: 0 },
                intensity: 30,
                color: { r: 0.8, g: 0.85, b: 1.0 },
                rotation: { x: 90, y: 0, z: 0 }
            }
        ]
    },
    dramatic_rim: {
        label: "Dramatic Rim",
        lights: [
            {
                name: "Rim Strong",
                type: "spot",
                position: { x: 0, y: 60, z: -120 },
                intensity: 100,
                color: { r: 1.0, g: 1.0, b: 1.0 },
                rotation: { x: 20, y: 0, z: 0 }
            },
            {
                name: "Fill Weak",
                type: "distant",
                position: { x: 80, y: 20, z: 80 },
