/**
 * master_render.dsa
 *
 * Main render loop for DAZ-to-LoRA. Accepts a JSON job file via ScriptArg
 * and executes unattended renders: loads a figure, applies looks (wardrobe,
 * hair, poses), iterates camera and lighting profiles, and saves renders.
 *
 * Usage:
 *   DAZStudio.exe -scriptArg <path_to_job.json> master_render.dsa -noPrompt -headless
 *
 * Job file schema: (see accompanying README or type definitions)
 */

// ═══════════════════════════════════════════════════════════════════════════════
//  Camera Definitions
// ═══════════════════════════════════════════════════════════════════════════════

/**
 * Hardcoded camera presets.
 * Each entry specifies position (x, y, z) and target (x, y, z).
 * Units are DAZ Studio scene units (centimeters).
 *
 * DAZ Script API for cameras:
 *   Scene.createCamera(name)           -> Camera object
 *   Camera.setPosition(x, y, z)        -> sets world-space position
 *   Camera.setTarget(x, y, z)          -> sets look-at target
 *   Camera.setFocalLength(mm)          -> sets focal length
 *   Camera.setActive()                 -> makes this the active view
 */
var HARDCODED_CAMERAS = {
    portrait_close: {
        label: "Portrait Close",
        position: { x: 0, y: 0, z: 60 },
        target:   { x: 0, y: 10, z: 0 },
        focalLength: 85
    },
    half_body: {
        label: "Half Body",
        position: { x: 0, y: 0, z: 120 },
        target:   { x: 0, y: 0, z: 0 },
        focalLength: 50
    },
    full_body_front: {
        label: "Full Body Front",
        position: { x: 0, y: 0, z: 200 },
        target:   { x: 0, y: 0, z: 0 },
        focalLength: 35
    },
    full_body_3q: {
        label: "Full Body 3-Quarter",
        position: { x: 140, y: 0, z: 140 },
        target:   { x: 0, y: 0, z: 0 },
        focalLength: 35
    },
    full_body_profile: {
        label: "Full Body Profile",
        position: { x: 200, y: 0, z: 0 },
        target:   { x: 0, y: 0, z: 0 },
        focalLength: 35
    },
    full_body_low_angle: {
        label: "Full Body Low Angle",
        position: { x: 0, y: -40, z: 140 },
        target:   { x: 0, y: 20, z: 0 },
        focalLength: 35
    },
    full_body_high_angle: {
        label: "Full Body High Angle",
        position: { x: 0, y: 60, z: 260 },
        target:   { x: 0, y: -10, z: 0 },
        focalLength: 35
    }
};

// ═══════════════════════════════════════════════════════════════════════════════
//  Lighting Definitions
// ═══════════════════════════════════════════════════════════════════════════════

/**
 * Hardcoded lighting rigs.
 * Each rig is an array of light definitions.
 *
 * DAZ Script API for lights:
 *   Scene.createLight(type, name)      -> Light object
 *   Light.setPosition(x, y, z)
 *   Light.setIntensity(value)          -> 0-100 or percentage
 *   Light.setColor(r, g, b)            -> RGB 0-1 range
 *   Light.setRotation(x, y, z)
 *   Light.setShadow(on/off)
 *   Light.setType("point"|"spot"|"distant"|"environment")
 *
 * NOTE: DAZ Studio lighting API varies. Some versions use Light.setLightType(),
 * Light.setEnable(), etc. We use the most common API calls and provide fallbacks.
 */
var HARDCODED_LIGHTING = {
    studio_3point: {
        label: "Studio 3-Point",
        lights: [
            {
                name: "Key",
                type: "distant",
                position: { x: -100, y: 80, z: 60 },
