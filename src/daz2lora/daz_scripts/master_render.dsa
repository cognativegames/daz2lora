                color: { r: 1.0, g: 0.98, b: 0.95 },
                rotation: { x: 45, y: -30, z: 0 }
            },
            {
                name: "Fill",
                type: "distant",
                position: { x: 80, y: 40, z: 80 },
                intensity: 40,
                color: { r: 0.95, g: 0.97, b: 1.0 },
                rotation: { x: 15, y: 20, z: 0 }
            },
            {
                name: "Rim",
                type: "distant",
                position: { x: 0, y: 100, z: -100 },
                intensity: 60,
